PORT=5000
NODE_ENV=development

# AI API Key (required for summarization)
# Get from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# JWT Secret (required for authentication)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# MongoDB URI (optional, currently using in-memory DB)
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/ai-notes-app?retryWrites=true&w=majority
